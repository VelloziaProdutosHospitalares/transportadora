APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Integração Octalog
OCTALOG_URL=https://integracao.octalog.com.br
OCTALOG_AUTH_URL=https://api.octalog.com.br
OCTALOG_USUARIO=
OCTALOG_SENHA=
# Webhook Octalog (POST em /api/octalog/webhook). Mesmo valor no header na Octalog (Authorization ou Bearer).
# Recebe: movimentações/tracking e/ou retornos de ticket SAC (array JSON na raiz).
# OCTALOG_WEBHOOK_SECRET=

# --- SERPRO — Consulta NF-e (API Gateway) ---
# 1) Consumer Key e Consumer Secret (Área do Cliente — identificam o contrato)
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
# Alternativa ao passo 1 (mesmo que base64(Consumer Key:Consumer Secret) sem "Basic "):
# SERPRO_BASIC_AUTH_BASE64=
#
# 2) Token OAuth2 (Bearer temporário): POST grant_type=client_credentials; Content-Type application/x-www-form-urlencoded
#    evita HTTP 415. Gateway São Paulo (recomendado):
SERPRO_TOKEN_URL=https://gateway.apiserpro.serpro.gov.br/token
# Gateway Brasília (deprecated na documentação SERPRO): https://apigateway.serpro.gov.br/token
#
# 4) Consulta: GET {base}/nfe/{chave44} + Accept application/json + Authorization Bearer (uma vez)
# Trial (demonstração); produção: ver Referência da API / swagger no contrato
SERPRO_CONSULTA_BASE_URL=https://gateway.apiserpro.serpro.gov.br/consulta-nfe-df-trial/api/v1
# SERPRO_TIMEOUT=30
# Se o token ou a consulta falharem com erro de certificado SSL (comum no WSL), use false — equivalente ao curl -k
# SERPRO_VERIFY_SSL=true
